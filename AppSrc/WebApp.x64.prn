37679>>>        tWebNavigateData NavigateData
37679>>>        tWebNavigateData NavigateData
37679>>>        Boolean bHasRecord
37679>>>        Handle hoDD
37679>>>
37679>>>        Get Server to hoDD
37680>>>        Get GetNavigateData to NavigateData
37681>>>        Get HasRecord of hoDD to bHasRecord
37682>>>
37682>>>        // let's hide all buttons and then Show the ones we want
37682>>>        WebSet pbRender of oEditBtn to False
37683>>>        WebSet pbRender of oSaveBtn to False
37684>>>        WebSet pbRender of oCancelChangesBtn to False
37685>>>        WebSet pbRender of oDeleteBtn to False
37686>>>
37686>>>        If (NavigateData.bReadOnly) Begin
37688>>>            WebSet pbRender of oEditBtn to True
37689>>>        End
37689>>>>
37689>>>        Else Begin
37690>>>            WebSet pbRender of oSaveBtn to True
37691>>>            WebSet pbRender of oCancelChangesBtn to True
37692>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37693>>>        End
37693>>>>
37693>>>    End_Procedure
