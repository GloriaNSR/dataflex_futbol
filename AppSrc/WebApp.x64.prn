37619>>>    Procedure SetActionButtons
37622>>>        tWebNavigateData NavigateData
37622>>>        tWebNavigateData NavigateData
37622>>>        Boolean bHasRecord
37622>>>        Handle hoDD
37622>>>
37622>>>        Get Server to hoDD
37623>>>        Get GetNavigateData to NavigateData
37624>>>        Get HasRecord of hoDD to bHasRecord
37625>>>
37625>>>        // let's hide all buttons and then Show the ones we want
37625>>>        WebSet pbRender of oEditBtn to False
37626>>>        WebSet pbRender of oSaveBtn to False
37627>>>        WebSet pbRender of oCancelChangesBtn to False
37628>>>        WebSet pbRender of oDeleteBtn to False
37629>>>
37629>>>        If (NavigateData.bReadOnly) Begin
