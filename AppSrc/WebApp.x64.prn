38404>>>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38407>>>>>        Case Begin
38407>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
38409>>>>>                // If from main, this is a propbably a main file Select to Zoom.
38409>>>>>                Case Break
38410>>>>>
38410>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
38413>>>>>                // If from parent, this is a constrained drill down.
38413>>>>>                Case Break
38414>>>>>
38414>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
38417>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38417>>>>>                Case Break
38418>>>>>
38418>>>>>            Case Else // must be nfUndefined
38418>>>>>
38418>>>>>        Case End
38418>>>>>
38418>>>>>        Send SetActionButtons
38419>>>>>
38419>>>>>    End_Procedure
