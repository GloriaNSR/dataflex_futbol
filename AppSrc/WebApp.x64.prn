37709>>>                // If from main, this is a propbably a main file Select to Zoom.
37709>>>                Case Break
37710>>>
37710>>>            Case (NavigateData.eNavigateType = nfFromParent)
37713>>>                // If from parent, this is a constrained drill down.
37713>>>                Case Break
37714>>>
37714>>>            Case (NavigateData.eNavigateType = nfFromChild)
37717>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37717>>>                Case Break
37718>>>
37718>>>            Case Else // must be nfUndefined
37718>>>
37718>>>        Case End
37718>>>
37718>>>        Send SetActionButtons
37719>>>
37719>>>    End_Procedure
