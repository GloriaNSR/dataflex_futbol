37716>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37716>>>                Case Break
37717>>>
37717>>>            Case Else // must be nfUndefined
37717>>>
37717>>>        Case End
37717>>>
37717>>>        Send SetActionButtons
