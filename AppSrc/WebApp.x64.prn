38410>>>>>        Case Begin
38410>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
38412>>>>>                // If from main, this is a propbably a main file Select to Zoom.
38412>>>>>                Case Break
38413>>>>>
38413>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
38416>>>>>                // If from parent, this is a constrained drill down.
38416>>>>>                Case Break
38417>>>>>
38417>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
38420>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38420>>>>>                Case Break
38421>>>>>
38421>>>>>            Case Else // must be nfUndefined
38421>>>>>
38421>>>>>        Case End
38421>>>>>
38421>>>>>        Send SetActionButtons
38422>>>>>
38422>>>>>    End_Procedure
