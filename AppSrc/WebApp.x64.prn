36731>>>>>>>        If (not(pBase64)) Begin
36733>>>>>>>            Function_Return ucaBuffer
36734>>>>>>>        End
36734>>>>>>>>
36734>>>>>>>        
36734>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36735>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36736>>>>>>>        Move (Free(pBase64)) to iLen
36737>>>>>>>        Function_Return ucaBuffer
36738>>>>>>>    End_Function
36739>>>>>>>    
36739>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36741>>>>>>>        Boolean bOk bRequireTimeCost
36741>>>>>>>        UChar[] ucaHash
36742>>>>>>>        
36742>>>>>>>        Case Begin
36742>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36744>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36745>>>>>>>                If (not(bOk)) Function_Return False
36748>>>>>>>                
36748>>>>>>>                Move True to bRequireTimeCost
36749>>>>>>>                Case Break
36750>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36753>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36754>>>>>>>                If (not(bOk)) Function_Return False
36757>>>>>>>                
36757>>>>>>>                Move True to bRequireTimeCost
36758>>>>>>>                Case Break
36759>>>>>>>            Case Else
36759>>>>>>>                Error 8710 "Invalid algorithm selected."
36760>>>>>>>>
36760>>>>>>>                Function_Return False
36761>>>>>>>        Case End
36761>>>>>>>        
36761>>>>>>>        String sSalt
36761>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36762>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36765>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36766>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36769>>>>>>>        
36769>>>>>>>        If (bRequireTimeCost) Begin
36771>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36772>>>>>>>        End
36772>>>>>>>>
36772>>>>>>>        Else Begin
36773>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36774>>>>>>>        End
36774>>>>>>>>
36774>>>>>>>        
36774>>>>>>>        Function_Return bOk
36775>>>>>>>    End_Function
36776>>>>>>>    
36776>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36778>>>>>>>        UChar[] ucaSalt
36779>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36780>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36783>>>>>>>        
36783>>>>>>>        If (num_arguments > 4) Begin
36785>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36786>>>>>>>        End
36786>>>>>>>>
36786>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36787>>>>>>>    End_Function
36788>>>>>>>    
36788>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36790>>>>>>>        Boolean bRequiresTimeCost
36790>>>>>>>        UInteger uiAlgo uiTimeCost
36790>>>>>>>        Integer iBegin iEnd
36790>>>>>>>        String sSalt
36790>>>>>>>        
36790>>>>>>>        Move 1 to iBegin
36791>>>>>>>        
36791>>>>>>>        // Parse Algo
36791>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36792>>>>>>>        If (not(iEnd)) Function_Return False
36795>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36796>>>>>>>        
36796>>>>>>>        // Parse Salt
36796>>>>>>>        Move (iEnd + 1) to iBegin
36797>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36798>>>>>>>        If (not(iEnd)) Function_Return False
36801>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36802>>>>>>>        
36802>>>>>>>        Case Begin
36802>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36804>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36807>>>>>>>                Move True to bRequiresTimeCost
36808>>>>>>>                Case Break
36809>>>>>>>            Case Else
36809>>>>>>>                Error 8710 "Invalid algorithm selected."
36810>>>>>>>>
36810>>>>>>>                Function_Return False
36811>>>>>>>        Case End
36811>>>>>>>        
36811>>>>>>>        // Parse optional timecost
36811>>>>>>>        If (bRequiresTimeCost) Begin
36813>>>>>>>            Move (iEnd + 1) to iBegin
36814>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36815>>>>>>>            If (not(iEnd)) Function_Return False
36818>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36819>>>>>>>        End
36819>>>>>>>>
36819>>>>>>>        
36819>>>>>>>        // Parse rest hash
36819>>>>>>>        Move (iEnd + 1) to iBegin
36820>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36821>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36824>>>>>>>        
36824>>>>>>>        // Base64Decode
36824>>>>>>>        UChar[] ucaSalt
36825>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36826>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36829>>>>>>>        
36829>>>>>>>        // Create new hash
36829>>>>>>>        String sNewHash
36829>>>>>>>        If (bRequiresTimeCost) Begin
36831>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36833>>>>>>>                Function_Return False 
36834>>>>>>>            End
36834>>>>>>>>
36834>>>>>>>        End
36834>>>>>>>>
36834>>>>>>>        Else Begin
36835>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36837>>>>>>>                Function_Return False 
36838>>>>>>>            End
36838>>>>>>>>
36838>>>>>>>        End
36838>>>>>>>>
36838>>>>>>>        Function_Return (sNewHash = sHash)
36839>>>>>>>    End_Function
36840>>>>>>>    
36840>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36842>>>>>>>        Boolean bRequireTimeCost
36842>>>>>>>        UBigInt ullSize
36842>>>>>>>        UChar[] ucaSalt
36843>>>>>>>        String sSalt
36843>>>>>>>        
36843>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36844>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36845>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36848>>>>>>>        
36848>>>>>>>        Case Begin
36848>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36850>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36851>>>>>>>                Move True to bRequireTimeCost
36852>>>>>>>                Case Break
36853>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36856>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36857>>>>>>>                Move True to bRequireTimeCost
36858>>>>>>>                Case Break
36859>>>>>>>            Case Else
36859>>>>>>>                Error 8710 "Invalid algorithm selected."
36860>>>>>>>>
36860>>>>>>>                Function_Return 0
36861>>>>>>>        Case End
36861>>>>>>>        
36861>>>>>>>        // calculate base64 in a non-floating-manner
36861>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36862>>>>>>>        
36862>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36863>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36864>>>>>>>        If (bRequireTimeCost) Begin
36866>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36867>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36868>>>>>>>        End
36868>>>>>>>>
36868>>>>>>>        Else Begin
36869>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36870>>>>>>>        End
36870>>>>>>>>
36870>>>>>>>        
36870>>>>>>>        Function_Return ullSize
36871>>>>>>>    End_Function
36872>>>>>>>End_Class
36873>>>>>>>
36873>>>>>>>Class cPasswordHasher is a cObject
36874>>>>>>>    
36874>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36875>>>>>>>    
36875>>>>>>>    Procedure Construct_Object
36877>>>>>>>        Forward Send Construct_Object
36879>>>>>>>        
36879>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36880>>>>>>>        Property UInteger   puiSaltSize         16
36881>>>>>>>        
36881>>>>>>>        Property UInteger   puiOptTimeCost      420000
36882>>>>>>>    End_Procedure
36883>>>>>>>    
36883>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36885>>>>>>>        Boolean bOk
36885>>>>>>>        UInteger uiAlgo
36885>>>>>>>        Get peAlgorithm to uiAlgo
36886>>>>>>>        
36886>>>>>>>        Case Begin
36886>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36888>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36891>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36892>>>>>>>                Case Break
36893>>>>>>>            Case Else
36893>>>>>>>                Error 8710 "Invalid algorithm selected."
36894>>>>>>>>
36894>>>>>>>                Function_Return False
36895>>>>>>>        Case End
36895>>>>>>>        
36895>>>>>>>        Function_Return bOk
36896>>>>>>>    End_Function
36897>>>>>>>    
36897>>>>>>>    Function RequiredBufferSize Returns UBigInt
36899>>>>>>>        UBigInt ullSize
36899>>>>>>>        UInteger uiAlgo
36899>>>>>>>        Get peAlgorithm to uiAlgo
36900>>>>>>>        
36900>>>>>>>        Case Begin
36900>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36902>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36905>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36906>>>>>>>                Case Break
36907>>>>>>>            Case Else
36907>>>>>>>                Error 8710 "Invalid algorithm selected."
36908>>>>>>>>
36908>>>>>>>                Function_Return 0
36909>>>>>>>        Case End
36909>>>>>>>        
36909>>>>>>>        Function_Return ullSize
36910>>>>>>>    End_Function
36911>>>>>>>
36911>>>>>>>End_Class
