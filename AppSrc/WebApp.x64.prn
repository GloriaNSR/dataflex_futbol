38567>>>                // If from parent, this is a constrained drill down
38567>>>                Case Break
38568>>>
38568>>>            Case (NavigateData.eNavigateType = nfFromChild)
38571>>>                // If from child, this is a probably a parent lookup from a Zoom
38571>>>                Case Break
38572>>>
38572>>>            Case (NavigateData.eNavigateType = nfFromMain)
38575>>>                // If from main, this is a probably a main-file lookup from a Zoom
38575>>>                WebSet pbRender of oDetailButton to False
38576>>>                Case Break
38577>>>
38577>>>            Case Else // must be nfUndefined
38577>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
38577>>>
38577>>>        Case End
38577>>>
38577>>>    End_Procedure
