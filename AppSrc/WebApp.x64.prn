38993>>>>>        WebSet pbRender of oSaveBtn to False
38994>>>>>        WebSet pbRender of oCancelChangesBtn to False
38995>>>>>        WebSet pbRender of oDeleteBtn to False
38996>>>>>
38996>>>>>        If (NavigateData.bReadOnly) Begin
