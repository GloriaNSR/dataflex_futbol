38479>>>                // If from main, this is a probably a main-file lookup from a Zoom
38479>>>                WebSet pbRender of oDetailButton to False
38480>>>                Case Break
38481>>>
38481>>>            Case Else // must be nfUndefined
38481>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
38481>>>
38481>>>        Case End
38481>>>
38481>>>    End_Procedure
