38310>>>>>
38310>>>>>        If (NavigateData.bReadOnly) Begin
38312>>>>>            WebSet pbRender of oEditBtn to True
38313>>>>>        End
38313>>>>>>
38313>>>>>        Else Begin
38314>>>>>            WebSet pbRender of oSaveBtn to True
38315>>>>>            WebSet pbRender of oCancelChangesBtn to True
38316>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38317>>>>>        End
38317>>>>>>
38317>>>>>    End_Procedure
