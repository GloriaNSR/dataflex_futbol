Use DataDict.pkg

Open entrenador
Open hijoentrenador
Open equipo

Class centrenadorDataDictionary is a DataDictionary
    
    Procedure Construct_Object
        Forward Send Construct_Object
        Set Main_File to entrenador.File_Number

        Set Add_Server_File to equipo.File_Number

        Set Add_Client_File to hijoentrenador.File_Number

        Set Foreign_Field_Option DD_KEYFIELD DD_NOPUT to True
        Set Foreign_Field_Option DD_KEYFIELD DD_FINDREQ to True
        Set Foreign_Field_Option DD_INDEXFIELD DD_NOPUT to True
        Set Foreign_Field_Option DD_DEFAULT DD_DISPLAYONLY to True
        
    End_Procedure
    
    
    // Dejar entrenador sin equipo (Despedir)
    
    Procedure Attach_Main_File
        Forward Send Attach_Main_File
        
        If (entrenador.EquipoID = 0) ;
        Set_Attribute DF_FIELD_IS_NULL of entrenador.File_Number (RefTable(entrenador.EquipoID)) to True
    End_Procedure

End_Class